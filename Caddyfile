# LoveCheck Production — Caddy Direct (No Cloudflare)
# Caddy auto-obtains Let's Encrypt TLS certificates.

# Redirect www to non-www
www.haball.cc, www.hbball.cc {
	redir https://{labels.1}.{labels.0}{uri} permanent
}

haball.cc, hbball.cc {
	# Security headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# Reverse proxy to frontend nginx (which handles SPA + API proxy)
	reverse_proxy frontend:80

	# Compress responses directly to client
	encode gzip zstd

	# Access log
	log {
		output file /data/access.log {
			roll_size 50MiB
			roll_keep 5
		}
	}
}
