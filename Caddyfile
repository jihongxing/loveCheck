# LoveCheck Production — Behind Cloudflare Proxy
# Cloudflare handles TLS termination. Caddy listens on HTTP only.
# Set Cloudflare SSL mode to "Flexible" or use Cloudflare Origin Certificate with "Full (Strict)".

:80 {
	# Security headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# Reverse proxy to frontend nginx (which handles SPA + API proxy)
	reverse_proxy frontend:80

	# Caddy compresses responses to Cloudflare edge
	encode gzip zstd

	# Access log
	log {
		output file /data/access.log {
			roll_size 50MiB
			roll_keep 5
		}
	}
}
