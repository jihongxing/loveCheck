# Trusted reverse proxy may set X-App-Geo-City (or CF-IPCity) for anonymous reporter region labels — never accept city from browser form fields.

# Admin panel secret key
ADMIN_SECRET=your_strong_admin_secret_here

# HMAC-SHA256 pepper for deterministic phone hashing (WARNING: changing after data exists breaks all lookups)
SEARCH_PEPPER=your_random_pepper_string_here

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=lovecheck
PG_PASSWORD=lovecheck_pwd
PG_DBNAME=lovecheck
PG_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=your_redis_password_here

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_USE_SSL=false

# Web Push (VAPID) - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@lovertrust.com

# Xunhupay (WeChat Pay)
XUNHU_APPID=your_xunhu_appid
XUNHU_APPSECRET=your_xunhu_appsecret
XUNHU_GATEWAY=https://api.xunhupay.com
PAY_NOTIFY_URL=https://yourdomain.com/api/v1/pay/notify
PAY_RETURN_URL=https://yourdomain.com/
PAY_PRICE=19.9

# Xunhupay (Alipay)
XUNHU_ALI_APPID=your_xunhu_alipay_appid
XUNHU_ALI_APPSECRET=your_xunhu_alipay_appsecret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_PRICE=2.99
PAYPAL_CURRENCY=USD

# Server
PORT=8080
GIN_MODE=debug
CORS_ORIGIN=*
