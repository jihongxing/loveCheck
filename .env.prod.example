# Production environment variables for docker-compose.prod.yml
# Copy to .env in the project root before running: docker-compose -f docker-compose.prod.yml up -d

# PostgreSQL
PG_PASSWORD=your_strong_pg_password

# Redis
REDIS_PASSWORD=your_strong_redis_password

# MinIO
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# Application
ADMIN_SECRET=your_strong_admin_secret
SEARCH_PEPPER=your_random_pepper_string

# CORS (set to your actual domain in production, e.g. https://lovertrust.com)
CORS_ORIGIN=*

# Xunhupay (WeChat Pay)
XUNHU_APPID=your_xunhu_appid
XUNHU_APPSECRET=your_xunhu_appsecret
PAY_NOTIFY_URL=https://yourdomain.com/api/v1/pay/notify
PAY_RETURN_URL=https://yourdomain.com/
PAY_PRICE=19.9

# Xunhupay (Alipay)
XUNHU_ALI_APPID=your_xunhu_alipay_appid
XUNHU_ALI_APPSECRET=your_xunhu_alipay_appsecret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=live
PAYPAL_PRICE=2.99
PAYPAL_CURRENCY=USD

# Public port (default 80)
PUBLIC_PORT=80
