# Production environment variables for docker-compose.prod.yml
# Copy to .env in the project root before running: docker compose -f docker-compose.prod.yml up -d
#
# Generate strong random values:  openssl rand -hex 32

# ─── Core Secrets (MUST change before deployment) ───

# PostgreSQL password
PG_PASSWORD=

# Redis password
REDIS_PASSWORD=

# MinIO credentials
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Admin panel login secret (use a strong random string)
ADMIN_SECRET=

# HMAC pepper for phone hashing — CANNOT be changed after data exists!
SEARCH_PEPPER=

# ─── Domain & CORS ───

# Primary domain (used for CORS, payment callbacks, etc.)
CORS_ORIGIN=https://haball.cc,https://hbball.cc

# ─── Payment: Xunhupay (WeChat) ───

XUNHU_APPID=
XUNHU_APPSECRET=
PAY_NOTIFY_URL=https://haball.cc/api/v1/pay/notify
PAY_RETURN_URL=https://haball.cc/
PAY_PRICE=19.9

# ─── Payment: Xunhupay (Alipay) ───

XUNHU_ALI_APPID=
XUNHU_ALI_APPSECRET=

# ─── Payment: PayPal ───

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_PRICE=2.99
PAYPAL_CURRENCY=USD

# ─── Web Push (VAPID) ───
# Generate with: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@haball.cc
